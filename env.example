# =============================================================================
# VELA — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================================

# -----------------------------------------------------------------------------
# BYTEPLUS MODELARK
# Docs: https://docs.byteplus.com/en/docs/ModelArk
# -----------------------------------------------------------------------------
MODELARK_API_KEY=
MODELARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
MODELARK_MODEL_ID=                    # format: ep-xxxxxxxxxxxxxxxx-xxxxx
MODELARK_EMBEDDING_MODEL_ID=          # separate endpoint for embeddings (optional)

# -----------------------------------------------------------------------------
# BYTEPLUS VIKINGDB
# Docs: https://docs.byteplus.com/en/docs/VikingDB
# -----------------------------------------------------------------------------
VIKINGDB_HOST=
VIKINGDB_REGION=ap-southeast-1
VIKINGDB_AK=
VIKINGDB_SK=
VIKINGDB_COLLECTION_NAME=vela_docs

# -----------------------------------------------------------------------------
# FEATURE FLAGS — set to "true" to use mock/fallback instead of real service
# Start with all true, flip to false once each integration is verified
# -----------------------------------------------------------------------------
USE_MOCK_VIKINGDB=true
USE_MOCK_SEARCH=true

# -----------------------------------------------------------------------------
# WEB SEARCH
# Serper: https://serper.dev (free: 2,500 queries/month, no card needed)
# Leave blank to fall back to DuckDuckGo (no key required)
# -----------------------------------------------------------------------------
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# DATABASE
# Local: uses Docker Compose postgres
# Railway: auto-set by Railway when you add the Postgres plugin
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vela

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
FLASK_ENV=development
FLASK_PORT=5000
FRONTEND_URL=http://localhost:5173    # update to Vercel URL after deploy
